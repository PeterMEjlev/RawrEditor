<Window x:Class="Rawr.Editor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Rawr.Editor.App.ViewModels"
        xmlns:ctl="clr-namespace:Rawr.Editor.App.Controls"
        Title="RAWR Editor — Develop"
        Height="860" Width="1340"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <!-- \ toggles Before/After like Lightroom. -->
        <KeyBinding Key="OemPipe" Command="{Binding ToggleBeforeCommand}" />
        <KeyBinding Key="OemBackslash" Command="{Binding ToggleBeforeCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Content="📂  Open RAW…"
                        Command="{Binding OpenCommand}" Margin="0,0,8,0" />
                <Button DockPanel.Dock="Left" Content="↺  Reset"
                        Command="{Binding ResetCommand}" Margin="0,0,8,0"
                        IsEnabled="{Binding HasPhoto}"
                        ToolTip="Reset every slider to its default" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding FileName}"
                           Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0" />

                <!-- View controls cluster (Export… is rightmost). -->
                <Button DockPanel.Dock="Right" Content="⤓  Export…"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding ExportAdvancedCommand}"
                        IsEnabled="{Binding HasPhoto}"
                        ToolTip="Choose format, bit depth, colour space and size" />
                <Button DockPanel.Dock="Right"
                        x:Name="CalibrationButton"
                        Content="Calibration TIFFs..."
                        Click="OnCalibrationButtonClick"
                        IsEnabled="{Binding HasPhoto}"
                        Margin="0,0,8,0"
                        ToolTip="Export -100, -50, +50 and +100 TIFFs for one slider">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Contrast"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Contrast" />
                            <MenuItem Header="Highlights"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Highlights" />
                            <MenuItem Header="Shadows"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Shadows" />
                            <MenuItem Header="Whites"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Whites" />
                            <MenuItem Header="Blacks"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Blacks" />
                            <Separator />
                            <MenuItem Header="Vibrance"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Vibrance" />
                            <MenuItem Header="Saturation"
                                      Command="{Binding ExportCalibrationSetCommand}"
                                      CommandParameter="Saturation" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button DockPanel.Dock="Right" Content="⤓  Export JPEG…"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding HasPhoto}"
                        Margin="0,0,8,0"
                        ToolTip="Quick full-resolution JPEG with the current edits" />
                <TextBlock DockPanel.Dock="Right"
                           x:Name="ZoomLabel"
                           Text="Fit"
                           Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center"
                           MinWidth="48"
                           TextAlignment="Right"
                           Margin="8,0,12,0" />
                <Button DockPanel.Dock="Right" Content="100%"
                        x:Name="OneToOneButton"
                        Click="OnOneToOneClick"
                        IsEnabled="{Binding HasPhoto}"
                        Margin="0,0,4,0"
                        ToolTip="Show the preview at 1 buffer pixel per screen pixel" />
                <Button DockPanel.Dock="Right" Content="Fit"
                        x:Name="FitButton"
                        Click="OnFitClick"
                        IsEnabled="{Binding HasPhoto}"
                        Margin="0,0,4,0"
                        ToolTip="Fit the photo to the viewer" />
                <ToggleButton DockPanel.Dock="Right" Content="⇄  Before"
                              Style="{StaticResource ToolbarToggleButton}"
                              IsChecked="{Binding IsShowingBefore, Mode=TwoWay}"
                              IsEnabled="{Binding HasPhoto}"
                              Margin="0,0,12,0"
                              ToolTip="Hide edits and show the unedited photo  (\)" />
            </DockPanel>
        </Border>

        <!-- ── Main: photo + adjustments ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Photo viewer. The Image is transformed via MatrixTransform so
                 the viewport can zoom (mouse wheel) and pan (drag) without
                 forcing WPF to re-layout on every interaction. -->
            <Border Grid.Column="0" Background="#FF0C0D10" ClipToBounds="True">
                <Grid x:Name="ViewerHost"
                      Background="Transparent"
                      ClipToBounds="True"
                      Focusable="True"
                      MouseWheel="OnViewerMouseWheel"
                      MouseLeftButtonDown="OnViewerMouseLeftButtonDown"
                      MouseLeftButtonUp="OnViewerMouseLeftButtonUp"
                      MouseMove="OnViewerMouseMove"
                      SizeChanged="OnViewerSizeChanged">
                    <Image x:Name="ViewerImage"
                           Source="{Binding PreviewImage}"
                           Stretch="Uniform"
                           StretchDirection="Both"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           RenderTransformOrigin="0.5,0.5"
                           IsHitTestVisible="False">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ViewerScale" ScaleX="1" ScaleY="1" />
                                <TranslateTransform x:Name="ViewerTranslate" X="0" Y="0" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>

                    <TextBlock Text="Open a RAW photo to begin  (Open RAW…)"
                               Foreground="{StaticResource TextDimBrush}"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="{Binding HasPhoto,
                                   Converter={StaticResource InverseBoolVis}}" />

                    <Border Background="#990C0D10"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsBusy,
                                Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Adjustments panel -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,16">
                    <StackPanel>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="WHITE BALANCE" Style="{StaticResource SectionCardHeader}" />
                                <ctl:AdjustmentRow Label="Temp"  Value="{Binding Temperature, Mode=TwoWay}" />
                                <ctl:AdjustmentRow Label="Tint"  Value="{Binding Tint, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="TONE" Style="{StaticResource SectionCardHeader}" />
                                <ctl:AdjustmentRow Label="Exposure" Value="{Binding Exposure, Mode=TwoWay}"
                                                   Minimum="-5" Maximum="5" Step="0.05" />
                                <ctl:AdjustmentRow Label="Contrast"   Value="{Binding Contrast, Mode=TwoWay}"
                                                   Version="{Binding ContrastVersion, Mode=TwoWay}"
                                                   VersionCount="{Binding ContrastVersionCount, Mode=OneTime}" />
                                <ctl:AdjustmentRow Label="Highlights" Value="{Binding Highlights, Mode=TwoWay}"
                                                   Version="{Binding HighlightsVersion, Mode=TwoWay}"
                                                   VersionCount="{Binding HighlightsVersionCount, Mode=OneTime}" />
                                <ctl:AdjustmentRow Label="Shadows"    Value="{Binding Shadows, Mode=TwoWay}"
                                                   Version="{Binding ShadowsVersion, Mode=TwoWay}"
                                                   VersionCount="{Binding ShadowsVersionCount, Mode=OneTime}" />
                                <ctl:AdjustmentRow Label="Whites"     Value="{Binding Whites, Mode=TwoWay}"
                                                   Version="{Binding WhitesVersion, Mode=TwoWay}"
                                                   VersionCount="{Binding WhitesVersionCount, Mode=OneTime}" />
                                <ctl:AdjustmentRow Label="Blacks"     Value="{Binding Blacks, Mode=TwoWay}"
                                                   Version="{Binding BlacksVersion, Mode=TwoWay}"
                                                   VersionCount="{Binding BlacksVersionCount, Mode=OneTime}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="PRESENCE" Style="{StaticResource SectionCardHeader}" />
                                <ctl:AdjustmentRow Label="Vibrance"   Value="{Binding Vibrance, Mode=TwoWay}" />
                                <ctl:AdjustmentRow Label="Saturation" Value="{Binding Saturation, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextDimBrush}" />
        </Border>
    </Grid>
</Window>
