<UserControl x:Class="Rawr.Editor.App.Controls.AdjustmentRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Margin="0,5">
    <Grid>
        <!-- Column 3 is always reserved for the version pill, even on rows
             that don't have versions (Exposure, Highlights). That way every
             slider in the panel lines up at the same right edge regardless
             of which rows happen to expose a v1/v2/… toggle. -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   Foreground="{StaticResource TextDimBrush}"
                   VerticalAlignment="Center" />

        <Slider Grid.Column="1"
                x:Name="PART_Slider"
                Style="{StaticResource AdjustmentSlider}"
                Minimum="{Binding Minimum, ElementName=Root}"
                Maximum="{Binding Maximum, ElementName=Root}"
                SmallChange="{Binding Step, ElementName=Root}"
                LargeChange="{Binding Step, ElementName=Root}"
                Value="{Binding Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                Margin="8,0"
                ToolTip="Double-click to reset" />

        <TextBox Grid.Column="2"
                 x:Name="PART_ValueBox"
                 Height="22"
                 Padding="3,0"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Center"
                 HorizontalContentAlignment="Right"
                 VerticalContentAlignment="Center"
                 FontFamily="Consolas"
                 Background="{StaticResource BgControlBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1"
                 CaretBrush="{StaticResource TextBrush}"
                 GotKeyboardFocus="OnValueBoxGotKeyboardFocus"
                 LostKeyboardFocus="OnValueBoxLostKeyboardFocus"
                 PreviewKeyDown="OnValueBoxPreviewKeyDown"
                 PreviewMouseLeftButtonDown="OnValueBoxPreviewMouseLeftButtonDown"
                 ToolTip="Type a value and press Enter" />

        <!-- Math-version cycle button. Hidden (not collapsed) on rows without
             multiple versions so the reserved column still holds layout. Click
             advances 1→2→…→N→1. ContentStringFormat is used instead of the
             binding's StringFormat because Button.Content is typed `object`,
             and StringFormat on object-typed bindings is unreliable. -->
        <Button Grid.Column="3"
                x:Name="PART_VersionButton"
                Content="{Binding Version, ElementName=Root}"
                ContentStringFormat="v{0}"
                Click="OnVersionClick"
                HorizontalAlignment="Stretch"
                Padding="0,1"
                Margin="6,0,0,0"
                FontSize="11"
                Visibility="{Binding HasVersions, ElementName=Root,
                                     Converter={StaticResource HiddenVis}}"
                ToolTip="Click to cycle through math versions for this slider" />
    </Grid>
</UserControl>
