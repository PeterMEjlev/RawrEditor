<UserControl x:Class="Rawr.Editor.App.Controls.AdjustmentRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Margin="0,5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="44" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   Foreground="{StaticResource TextDimBrush}"
                   VerticalAlignment="Center" />

        <Slider Grid.Column="1"
                x:Name="PART_Slider"
                Style="{StaticResource AdjustmentSlider}"
                Minimum="{Binding Minimum, ElementName=Root}"
                Maximum="{Binding Maximum, ElementName=Root}"
                SmallChange="{Binding Step, ElementName=Root}"
                LargeChange="{Binding Step, ElementName=Root}"
                Value="{Binding Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                Margin="8,0"
                ToolTip="Double-click to reset" />

        <TextBlock Grid.Column="2"
                   Text="{Binding Value, ElementName=Root, StringFormat={}{0:0.##}}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontFamily="Consolas" />
    </Grid>
</UserControl>
