<Window x:Class="Rawr.Editor.App.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export"
        SizeToContent="Height"
        Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="RowLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgPanelBrush}" Padding="0">
        <StackPanel>

            <!-- Header -->
            <Border Background="{StaticResource BgToolbarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
            </Border>

            <StackPanel Margin="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Image Type -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Image Type" Style="{StaticResource RowLabel}" />
                    <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                              SelectedIndex="{Binding FormatIndex, Mode=TwoWay}">
                        <ComboBoxItem>JPEG</ComboBoxItem>
                        <ComboBoxItem>TIFF</ComboBoxItem>
                        <ComboBoxItem>PNG</ComboBoxItem>
                    </ComboBox>

                    <!-- Dimensions -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Dimensions" Style="{StaticResource RowLabel}" />
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  SelectedIndex="{Binding DimensionsIndex, Mode=TwoWay}">
                            <ComboBoxItem>Full Size</ComboBoxItem>
                            <ComboBoxItem>Long Edge</ComboBoxItem>
                        </ComboBox>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Margin="8,0,0,0"
                                    IsEnabled="{Binding LongEdgeEnabled}">
                            <TextBox Width="64" Height="28"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0"
                                     Background="{StaticResource BgControlBrush}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Text="{Binding LongEdgePixels, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="px" Style="{StaticResource RowLabel}" Margin="6,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Bit Depth -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Bit Depth" Style="{StaticResource RowLabel}" />
                    <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"
                              IsEnabled="{Binding BitDepthEnabled}"
                              SelectedIndex="{Binding BitDepthIndex, Mode=TwoWay}">
                        <ComboBoxItem>8 bits</ComboBoxItem>
                        <ComboBoxItem>16 bits</ComboBoxItem>
                    </ComboBox>

                    <!-- Compression (TIFF) -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Compression" Style="{StaticResource RowLabel}" />
                    <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"
                              IsEnabled="{Binding CompressionEnabled}"
                              SelectedIndex="{Binding CompressionIndex, Mode=TwoWay}">
                        <ComboBoxItem>None</ComboBoxItem>
                        <ComboBoxItem>LZW</ComboBoxItem>
                        <ComboBoxItem>ZIP</ComboBoxItem>
                    </ComboBox>

                    <!-- Quality (JPEG) -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Quality" Style="{StaticResource RowLabel}"
                               Visibility="{Binding QualityVisible, Converter={StaticResource BoolVis}}" />
                    <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"
                          Visibility="{Binding QualityVisible, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="1" Maximum="100"
                                Style="{StaticResource AdjustmentSlider}"
                                VerticalAlignment="Center"
                                Value="{Binding JpegQuality, Mode=TwoWay}" />
                        <TextBlock Grid.Column="1" MinWidth="28" TextAlignment="Right"
                                   Margin="8,0,0,0"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="{Binding JpegQuality}" />
                    </Grid>

                    <!-- Color Space -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Color Space" Style="{StaticResource RowLabel}" />
                    <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,2"
                              SelectedIndex="{Binding ColorSpaceIndex, Mode=TwoWay}">
                        <ComboBoxItem>sRGB</ComboBoxItem>
                        <ComboBoxItem>Adobe RGB</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <!-- Footer buttons -->
            <Border Background="{StaticResource BgToolbarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" MinWidth="84" Margin="0,0,8,0"
                            IsCancel="True" Click="OnCancel" />
                    <Button Content="Export…" MinWidth="96"
                            Style="{StaticResource AccentButton}"
                            IsDefault="True" Click="OnExport" />
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</Window>
