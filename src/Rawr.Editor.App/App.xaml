<Application x:Class="Rawr.Editor.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rawr.Editor.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolVis" />
            <conv:BoolToVisibilityConverter x:Key="InverseBoolVis" Invert="True" />
            <conv:BoolToVisibilityConverter x:Key="HiddenVis" UseHidden="True" />
            <conv:NullToVisibilityConverter x:Key="NotNullVis" />
            <conv:NullToVisibilityConverter x:Key="NullVis" Invert="True" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
